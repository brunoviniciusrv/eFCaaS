# ─────────────────────────────────────────────────────────────────
# Copie para .env e preencha os valores antes de rodar docker compose
# ─────────────────────────────────────────────────────────────────

# Banco de dados
DB_NAME=efcaas
DB_USER=efcaas
DB_PASSWORD=efcaas_senha_segura

# JWT — OBRIGATÓRIO trocar em produção (string aleatória >= 32 chars)
JWT_SECRET=troque-para-uma-string-aleatoria-de-256-bits-em-producao
JWT_EXPIRATION_MINUTES=60

# CORS — origens permitidas separadas por vírgula
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
