# ─────────────────────────────────────────────────────────────────
# Copie para .env e preencha os valores antes de rodar docker compose
# ─────────────────────────────────────────────────────────────────

# Banco de dados
DB_NAME=efcaas
DB_USER=efcaas
DB_PASSWORD=efcaas

# JWT — OBRIGATÓRIO trocar em produção (string aleatória >= 32 chars)
JWT_SECRET=troque-para-uma-string-aleatoria-de-256-bits-em-producao
JWT_EXPIRATION_MINUTES=60

# CORS — origens permitidas separadas por vírgula
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Ingestão externa (header X-Ingest-Api-Key)
INGEST_API_KEY=efcaas-ingest-dev-key

# MinIO (evidências) — defaults do docker-compose
MINIO_ACCESS_KEY=efcaas
MINIO_SECRET_KEY=efcaas123456

# Redis — usado pelo compose para rate limit / dedup
REDIS_HOST=redis
REDIS_PORT=6379

# Google Gemini — necessário para Trend Analyzer no front-end (profile full)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
