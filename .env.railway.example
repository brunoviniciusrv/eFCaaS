# ─────────────────────────────────────────────────────────────────
# Exemplo de variáveis para colar no Railway (serviço API)
# Substitua URLs e segredos antes de usar em produção.
# ─────────────────────────────────────────────────────────────────

SPRING_PROFILES_ACTIVE=prod

# Postgres — use Variable Reference no painel (${{Postgres.*}})
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# Segurança
JWT_SECRET=gere-uma-string-aleatoria-com-pelo-menos-32-caracteres
JWT_EXPIRATION_MINUTES=60

# URLs públicas (ajuste após gerar domínios no Railway)
API_PUBLIC_URL=https://SUA-API.up.railway.app/api/v1
FRONTEND_URL=https://SEU-FRONT.up.railway.app
CORS_ORIGINS=https://SEU-FRONT.up.railway.app

# Storage MinIO
MINIO_ENDPOINT=https://SEU-MINIO.up.railway.app
MINIO_ACCESS_KEY=efcaas
MINIO_SECRET_KEY=troque-esta-senha
MINIO_BUCKET=efcaas-evidencias

# Ingest
INGEST_API_KEY=gere-uma-chave-aleatoria
INGEST_DEFAULT_TENANT_SLUG=dev

# Redis — false se não provisionar Redis
ABUSE_REDIS_ENABLED=false

# E-mail — false em testes (links vão para log da API)
MAIL_ENABLED=false
MAIL_FROM=noreply@efcaas.com

# ─────────────────────────────────────────────────────────────────
# Frontend (serviço efcaas-frontend) — build time
# ─────────────────────────────────────────────────────────────────
# VITE_API_URL=https://SUA-API.up.railway.app/api/v1
# GEMINI_API_KEY=
